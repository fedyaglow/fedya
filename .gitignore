# Fedya Glow - .gitignore

# ===== FICHIERS OS =====
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ===== ÉDITEURS =====
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# ===== LOGS =====
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ===== FICHIERS TEMPORAIRES =====
*.tmp
*.temp
~*
*.bak
*.backup

# ===== NODE MODULES (si ajouté plus tard) =====
node_modules/
npm-debug.log
yarn.lock
package-lock.json

# ===== BUILD / DIST (si ajouté plus tard) =====
dist/
build/
out/
.cache/

# ===== ENVIRONNEMENT =====
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ===== COVERAGE (si tests ajoutés) =====
coverage/
.nyc_output/

# ===== FICHIERS SYSTÈME =====
*.pid
*.seed
*.pid.lock

# ===== FICHIERS ÉDITEUR SPÉCIFIQUES =====
# WebStorm
.idea/

# Visual Studio Code
.vscode/
*.code-workspace

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]

# ===== NETLIFY =====
.netlify/

# ===== VERCEL =====
.vercel/

# ===== AUTRES =====
# Fichiers de configuration personnels
config.local.js
settings.local.json

# Fichiers de test
test/
tests/
__tests__/

# Documentation temporaire
docs/temp/
